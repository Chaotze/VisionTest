<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="{{.Name}}"
        Arguments=""
        InstallLocation="C:\Program Files\{{.Info.CompanyName}}\{{.Info.ProductName}}">
    </Installer>
    <PackageInformation
        PackageName="VISIONTEST"
        PackageDisplayName="VISIONTEST"
        PublisherName="CN=Chaotze"
        PublisherDisplayName="Chaotze"
        Version="1.0.60606.0"
        PackageDescription="创新交互赋能视力筛查，守护清晰视界">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="cn.chaotze.visiontest"
                Description="创新交互赋能视力筛查，守护清晰视界"
                DisplayName="VISIONTEST"
                ExecutableName="visiontest"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>VISIONTEST</DisplayName>
            <PublisherDisplayName>Chaotze</PublisherDisplayName>
            <Description>创新交互赋能视力筛查，守护清晰视界</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="visiontest.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
